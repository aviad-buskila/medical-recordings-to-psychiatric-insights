APP_ENV=dev
LOG_LEVEL=INFO

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=clinical_ai
POSTGRES_USER=clinical_user
POSTGRES_PASSWORD=clinical_pass
POSTGRES_SCHEMA=clinical_ai

HF_TOKEN=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b
OLLAMA_JUDGE_MODEL=gemma3:12b
OLLAMA_INSIGHTS_MODEL=medaibase/medgemma1.5:4b
OLLAMA_TIMEOUT_S=600
OLLAMA_INSIGHTS_MAX_TOKENS=4000

STT_PROVIDER=mlx-whisper
STT_MODEL=mlx-community/whisper-large-v3-turbo
STT_MODEL_FALLBACK=mlx-community/whisper-large-v3-turbo
STT_MLX_QUALITY_MODEL=mlx-community/whisper-large-v3-mlx
STT_MLX_QUALITY_FALLBACK_MODEL=mlx-community/whisper-large-v3-turbo

DATA_ROOT=./data/raw
TRANSCRIPTS_DIR=./data/raw/transcripts
CASENOTES_DIR=./data/raw/casenotes
RECORDINGS_DIR=./data/raw/recordings
DATASET_PICKLE_PATH=./data/raw/dataset.pickle
GENERATED_TRANSCRIPTS_DIR=./data/generated_transcripts
INSIGHTS_EXTRACT_DIR=./data/processed/insights_extract

# Encoder for `run-bertscore` (BERTScore; see README)
# roberta-large is the default and widely supported.
# For clinical/biomedical transcription evaluation, a domain-specific encoder
# produces more meaningful semantic similarity scores. Recommended alternatives:
#   dmis-lab/biobert-base-cased-v1.2   (biomedical; best for drug names, diagnoses)
#   allenai/scibert_scivocab_uncased   (scientific text)
BERTSCORE_MODEL=dmis-lab/biobert-base-cased-v1.2
